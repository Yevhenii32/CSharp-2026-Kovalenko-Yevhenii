<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:ProductManager.UI.Converters"
             xmlns:models="clr-namespace:ProductManager.DTOModels.Product;assembly=ProductManager.DTOModels"
             xmlns:vms="clr-namespace:ProductManager.UI.ViewModels"
             x:Class="ProductManager.UI.Pages.WarehouseDetailsPage"
             x:DataType="vms:WarehouseDetailsViewModel"
             Title="Деталі складу" BackgroundColor="#E9ECEF" IsEnabled="{Binding IsNotBusy}">

    <ContentPage.Resources>
        <conv:EnumToDisplayNameConverter x:Key="EnumConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, *, Auto" Padding="20" RowSpacing="15" MaximumWidthRequest="600" HorizontalOptions="Center">

        <Frame Grid.Row="0" Margin="0" Padding="20" CornerRadius="15" HasShadow="True" BackgroundColor="White">
            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding CurrentWarehouse.Name}" FontSize="22" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="Center"/>
                <Label Text="{Binding CurrentWarehouse.Location, Converter={StaticResource EnumConverter}, StringFormat='Локація: {0}'}" FontSize="16" TextColor="#7F8C8D" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Frame>

        <VerticalStackLayout Grid.Row="1" Spacing="10">
            <Label Text="Список товарів:" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" />
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                <SearchBar Grid.Column="0" Placeholder="Пошук товарів..." Text="{Binding SearchText}" BackgroundColor="White" />
                <Picker Grid.Column="1" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSortOption}" BackgroundColor="White" WidthRequest="150" />
            </Grid>
        </VerticalStackLayout>

        <RefreshView Grid.Row="2" Command="{Binding RefreshDataCommand}">
            <CollectionView ItemsSource="{Binding Products}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProductListDTO">
                        <Frame Margin="0" Padding="15" CornerRadius="15" HasShadow="True" BackgroundColor="#C7EBFF">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vms:WarehouseDetailsViewModel}}, Path=GotoProductDetailsCommand}" CommandParameter="{Binding .}"/>
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" />
                                    <Label Text="{Binding Price, StringFormat='{0} ₴'}" FontSize="16" TextColor="#0080FF" FontAttributes="Bold" />
                                </VerticalStackLayout>

                                <Button Grid.Column="1" Text="✎" BackgroundColor="#F39C12" TextColor="White" FontAttributes="Bold" CornerRadius="8" WidthRequest="45"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vms:WarehouseDetailsViewModel}}, Path=EditProductCommand}" CommandParameter="{Binding .}"/>

                                <Button Grid.Column="2" Text="X" BackgroundColor="#E74C3C" TextColor="White" FontAttributes="Bold" CornerRadius="8" WidthRequest="45"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vms:WarehouseDetailsViewModel}}, Path=DeleteProductCommand}" CommandParameter="{Binding .}"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button Grid.Row="3" Command="{Binding AddProductCommand}" Text="Додати новий товар" CornerRadius="10" />

        <BoxView Grid.RowSpan="4" IsVisible="{Binding IsBusy}" BackgroundColor="Gray" Opacity="0.2" InputTransparent="False" />
        <ActivityIndicator Grid.RowSpan="4" Color="#0080FF" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" />
    </Grid>
</ContentPage>
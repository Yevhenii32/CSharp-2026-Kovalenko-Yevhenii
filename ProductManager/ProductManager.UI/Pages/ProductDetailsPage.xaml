<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProductManager.UI.Pages.ProductDetailsPage"
             Title="Деталі товару"
             BackgroundColor="#E9ECEF"
             Shell.BackgroundColor="#E9ECEF">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" MaximumWidthRequest="600" HorizontalOptions="Center">

            <Frame Margin="0" Padding="25" CornerRadius="15" HasShadow="True" BackgroundColor="White">
                <VerticalStackLayout Spacing="10">

                    <Label Text="{Binding Name}" 
                           FontSize="26" 
                           FontAttributes="Bold" 
                           TextColor="#2C3E50" 
                           HorizontalOptions="Center" />

                    <BoxView HeightRequest="1" Color="#BDC3C7" Margin="0,10" />

                    <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="15">
                        <Label Grid.Row="0" Grid.Column="0" Text="Категорія:" FontSize="16" TextColor="#7F8C8D" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Category}" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="End" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Кількість на складі:" FontSize="16" TextColor="#7F8C8D" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Quantity, StringFormat='{0} шт.'}" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="End" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Ціна за одиницю:" FontSize="16" TextColor="#7F8C8D" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Price, StringFormat='{0} ₴'}" FontSize="16" FontAttributes="Bold" TextColor="#0080FF" HorizontalOptions="End" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Вартість партії:" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding TotalValue, StringFormat='{0} ₴'}" FontSize="18" FontAttributes="Bold" TextColor="#0080FF" HorizontalOptions="End" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#BDC3C7" Margin="0,10" />

                    <Label Text="Опис товару" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" />
                    <Label Text="{Binding Description}" FontSize="16" TextColor="#34495E" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>